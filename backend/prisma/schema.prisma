// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

 model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  name          String
  password      String
  phone         String?
  type          UserType       @default(USER)
  createdAt     DateTime       @default(now())
  churchId      Int?           @unique
  church        Iglesia?       @relation("UserChurch", fields: [churchId], references: [id])
  registrations Registration[] @relation("UserRegistrations")
}

model Iglesia {
  id           Int          @id @default(autoincrement())
  name         String
  denomination String
  phone        String?
  userId       Int?         @unique
  user         User?        @relation("UserChurch")
  campamentos  Campamento[] @relation("CampamentoChurch")
}

model Campamento {
  id            Int            @id @default(autoincrement())
  name          String
  description   String?
  location      String
  startDate     DateTime
  endDate       DateTime
  price         Float
  churchId      Int
  church        Iglesia        @relation("CampamentoChurch", fields: [churchId], references: [id])
  createdAt     DateTime       @default(now())
  registrations Registration[] @relation("CampamentoRegistrations")
}

model Registration {
  id           Int        @id @default(autoincrement())
  userId       Int
  user         User       @relation("UserRegistrations", fields: [userId], references: [id])
  campamentoId Int
  campamento   Campamento @relation("CampamentoRegistrations", fields: [campamentoId], references: [id])
  fullName     String
  email        String
  phone        String
  createdAt    DateTime   @default(now())
}

enum UserType {
  USER
  IGLESIA
}
