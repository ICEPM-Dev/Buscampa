{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/auth/(google|facebook|x)(/callback)?",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/api/auth/(google|facebook|x)(/callback)?",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/robots.txt",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/sitemap.xml",
      "dest": "backend/api/index.ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.ts",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"]
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/assets/$1"
    },
    {
      "src": "/vite.svg",
      "dest": "frontend/vite.svg"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "frontend/$1",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}
